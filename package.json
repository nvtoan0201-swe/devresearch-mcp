{
  "name": "devresearch-mcp",
  "version": "0.2.0",
  "description": "Cross-platform dev research MCP with hype-vs-substance detection (HN + Reddit + Lobsters)",
  "type": "module",
  "author": "Toan Nguyen",
  "bin": {
    "devresearch-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && node -e \"require('fs').copyFileSync('src/storage/schema.sql', 'dist/storage/schema.sql')\"",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "claude-code",
    "anthropic",
    "research",
    "hype-detection",
    "developer-tools",
    "hackernews",
    "reddit",
    "lobsters"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nvtoan0201-swe/devresearch-mcp.git"
  },
  "homepage": "https://github.com/nvtoan0201-swe/devresearch-mcp#readme",
  "bugs": {
    "url": "https://github.com/nvtoan0201-swe/devresearch-mcp/issues"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "smol-toml": "^1.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
